# Scratch directory for diagnosis notes / one-off forensic dumps
# (e.g. temp/session-respawn-oom-root-cause.md). Keep untracked so
# investigations don't clutter the repo, but stay in the working
# tree for the agent that produced them to keep iterating.
# Anchored with a leading slash so we only catch the repo-root
# temp/, not nested directories that happen to be named temp.
/temp/
# TypeScript incremental build cache
*.tsbuildinfo

# Stray `tsc -b` / `tsc --declaration` emit.
#
# Why: the project is built by electron-vite; tsc is only used for
# type-checking. But the two tsconfigs (web + node) have
# `composite: true`, which FORCES emit — `tsc --noEmit` is rejected
# by tsc in composite mode. If someone runs `tsc -b` from the repo
# root the emit lands next to every `.ts` source, polluting src/
# with ~200 `.js` / `.d.ts` files that look identical to sources in
# file listings.
#
# The tsconfigs now set `outDir: ./.tsc-out/...` so future emits go
# there instead (see tsconfig.web.json, tsconfig.node.json). The
# rules below are defensive: if someone reverts the outDir or runs
# tsc with different flags, we still refuse to stage the drift.
#
# We have exactly TWO hand-authored `.d.ts` files tracked under src/
# (`src/preload/index.d.ts` augments `window.api`; `src/renderer/src/
# vite-env.d.ts` is vite's default client types). Plus one under
# testing/. Those are explicitly re-included.
/.tsc-out/
/electron.vite.config.js
/electron.vite.config.d.ts
/src/**/*.js
/src/**/*.d.ts
!/src/preload/index.d.ts
!/src/renderer/src/vite-env.d.ts
/testing/**/*.js
/testing/**/*.mjs
/testing/**/*.d.ts
/testing/**/*.d.mts
!/testing/rendering/renderer/vite-env.d.ts

# Reference material we read for understanding CC's internals — not part
# of cc-shell, intentionally left untracked. Live next to the project as
# a developer's local checkout.
vendor/claude-code-src/
# In-progress reproduction harnesses (e.g. paste-submit-repro,
# dictation-repro, opencode). These are isolated checkouts used
# to bisect bugs against minimal inputs; they live inside
# vendor/ so they sit next to claude-code-src above but they are
# emphatically NOT part of cc-shell and must not be committed.
vendor/in_progress/
file-dumps/
.proxy-testing/

# Stale mitmproxy run directories. The proxy runtime now targets
# ~/.config/cc-shell/proxy/... (see claudeSession.ts), but a prior
# version dropped these at the cwd. They contain TLS keylogs and
# decrypted Anthropic transport events — MUST NOT be committed.
2[0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T*Z/


# Local environment overrides
.env

# Git worktrees (parallel branches checked out under the repo).
# Kept hidden + ignored so `git status` from the main checkout never
# tries to track the contents of sibling branches.
.worktrees/

{
  "compilerOptions": {
    "composite": true,
    // Project is built by electron-vite; tsc is type-check-only. But
    // `composite: true` forces emit — `tsc --noEmit` is rejected in
    // composite mode. Redirect emit to a gitignored scratch dir so
    // `tsc -b` doesn't pollute src/ with ~200 `.js` / `.d.ts` files
    // sitting next to every source. See .gitignore for the full story.
    "outDir": "./.tsc-out/web",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "types": ["node"]
  },
  "include": [
    "src/renderer/**/*",
    "src/preload/index.d.ts",
    "src/shared/code/**/*",
    "src/shared/types/**/*",
    "src/shared/parsers/**/*",
    "src/providers/*/parsers/**/*",
    "src/providers/*/renderer/**/*",
    "testing/**/*"
  ]
}

{
  "name": "cc-shell",
  "version": "0.0.1",
  "description": "Desktop shell for Claude Code — hidden PTY, custom UI",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "proxy-demo-bootstrap": "npm --prefix claude-code-headless run proxy-test-bootstrap",
    "proxy-demo": "npm --prefix claude-code-headless run build && electron experiments/claude-proxy-stream-app/main.mjs",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^6.0.0",
    "agent-transcript-parser": "file:./agent-transcript-parser",
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "typescript-language-server": "^4.4.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}

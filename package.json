{
  "name": "agent-code",
  "version": "0.0.2-beta.1",
  "description": "Agent Code desktop app",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build:app": "electron-vite build && node scripts/copy-packaged-resources.mjs",
    "build": "npm run build:app",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "package:mac": "electron-builder --mac --publish never",
    "dist:mac": "npm run build && npm run package:mac",
    "start": "electron-vite preview",
    "testing:rendering": "npm run testing:rendering:build && electron testing/rendering/out/main/main.js",
    "testing:rendering:build": "electron-vite build --config testing/rendering/electron.vite.config.ts",
    "testing:rendering:preview": "electron testing/rendering/out/main/main.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:unit": "NODE_ENV=test vitest run --project unit",
    "test:integration": "NODE_ENV=test vitest run --project integration",
    "test:renderer": "NODE_ENV=test vitest run --project renderer",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "proxy-demo": "npm --prefix packages/claude-code-headless run build && electron experiments/claude-proxy-stream-app/main.mjs",
    "runtime:fetch:mitmproxy": "node scripts/runtime-tools/fetch-mitmproxy.mjs",
    "runtime:verify:mitmproxy": "node scripts/runtime-tools/verify-mitmproxy.mjs",
    "runtime:fetch:tmux": "node scripts/runtime-tools/fetch-tmux.mjs",
    "runtime:verify:tmux": "node scripts/runtime-tools/verify-tmux.mjs",
    "runtime:verify": "npm run runtime:verify:mitmproxy && npm run runtime:verify:tmux",
    "upstream:check": "node scripts/check-upstream.mjs",
    "runtime:prepare:mac": "npm run runtime:fetch:mitmproxy -- --all && npm run runtime:fetch:tmux -- --all && node scripts/runtime-tools/verify-mitmproxy.mjs --strict && node scripts/runtime-tools/verify-tmux.mjs --strict",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^6.0.0",
    "agent-transcript-parser": "file:./packages/agent-transcript-parser",
    "agent-voice-dictation": "file:./packages/agent-voice-dictation",
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "pidtree": "^0.6.0",
    "pidusage": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "typescript-language-server": "^4.4.0",
    "vscode-icons-js": "^11.6.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "ws": "^8.20.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
